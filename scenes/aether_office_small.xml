<?xml version="1.0" encoding="utf-8"?>
<!-- Aether Core PRESET: office_small (6 × 4 × 2.5 m) -->
<scene version="3.0.0">

  <integrator type="path"/>

  <sensor type="perspective">
    <float name="fov" value="60"/>
    <transform name="to_world">
      <lookat origin="3, -3, 1.8" target="3, 2, 1.2" up="0, 0, 1"/>
    </transform>
    <film type="hdrfilm">
      <integer name="width"  value="640"/>
      <integer name="height" value="480"/>
    </film>
  </sensor>

  <bsdf type="diffuse" id="mat-itu_plasterboard">
    <rgb name="reflectance" value="0.8, 0.8, 0.75"/>
  </bsdf>
  <bsdf type="diffuse" id="mat-itu_metal">
    <rgb name="reflectance" value="0.85, 0.85, 0.85"/>
  </bsdf>
  <bsdf type="diffuse" id="mat-itu_wood">
    <rgb name="reflectance" value="0.5, 0.3, 0.2"/>
  </bsdf>

  <!-- ODA: 6 × 4 × 2.5 m, alçıpan duvarlar (ofis) -->
  <shape type="rectangle" id="floor">
    <transform name="to_world">
      <scale x="3" y="2"/>
      <translate x="3" y="2" z="0"/>
    </transform>
    <ref id="mat-itu_plasterboard"/>
  </shape>

  <shape type="rectangle" id="ceiling">
    <transform name="to_world">
      <scale x="3" y="2"/>
      <rotate x="1" angle="180"/>
      <translate x="3" y="2" z="2.5"/>
    </transform>
    <ref id="mat-itu_plasterboard"/>
  </shape>

  <shape type="rectangle" id="wall_front">
    <transform name="to_world">
      <scale x="3" y="1.25"/>
      <rotate x="1" angle="-90"/>
      <translate x="3" y="0" z="1.25"/>
    </transform>
    <ref id="mat-itu_plasterboard"/>
  </shape>

  <shape type="rectangle" id="wall_back">
    <transform name="to_world">
      <scale x="3" y="1.25"/>
      <rotate x="1" angle="90"/>
      <translate x="3" y="4" z="1.25"/>
    </transform>
    <ref id="mat-itu_plasterboard"/>
  </shape>

  <shape type="rectangle" id="wall_left">
    <transform name="to_world">
      <scale x="1.25" y="2"/>
      <rotate y="1" angle="90"/>
      <translate x="0" y="2" z="1.25"/>
    </transform>
    <ref id="mat-itu_plasterboard"/>
  </shape>

  <shape type="rectangle" id="wall_right">
    <transform name="to_world">
      <scale x="1.25" y="2"/>
      <rotate y="1" angle="-90"/>
      <translate x="6" y="2" z="1.25"/>
    </transform>
    <ref id="mat-itu_plasterboard"/>
  </shape>

  <!-- RAF: merkez (3, 2, 1.2) -->
  <shape type="cube" id="shelf_frame">
    <transform name="to_world">
      <scale x="0.5" y="0.2" z="0.5"/>
      <translate x="3" y="2" z="1.2"/>
    </transform>
    <ref id="mat-itu_metal"/>
  </shape>

  <!-- 6 SLOT NESNESİ -->
  <shape type="cube" id="slot_obj_1">
    <transform name="to_world">
      <scale x="0.20" y="0.15" z="0.125"/>
      <translate x="2.75" y="2.0" z="1.53"/>
    </transform>
    <ref id="mat-itu_wood"/>
  </shape>
  <shape type="cube" id="slot_obj_2">
    <transform name="to_world">
      <scale x="0.20" y="0.15" z="0.125"/>
      <translate x="3.25" y="2.0" z="1.53"/>
    </transform>
    <ref id="mat-itu_wood"/>
  </shape>
  <shape type="cube" id="slot_obj_3">
    <transform name="to_world">
      <scale x="0.20" y="0.15" z="0.125"/>
      <translate x="2.75" y="2.0" z="1.20"/>
    </transform>
    <ref id="mat-itu_wood"/>
  </shape>
  <shape type="cube" id="slot_obj_4">
    <transform name="to_world">
      <scale x="0.20" y="0.15" z="0.125"/>
      <translate x="3.25" y="2.0" z="1.20"/>
    </transform>
    <ref id="mat-itu_wood"/>
  </shape>
  <shape type="cube" id="slot_obj_5">
    <transform name="to_world">
      <scale x="0.20" y="0.15" z="0.125"/>
      <translate x="2.75" y="2.0" z="0.87"/>
    </transform>
    <ref id="mat-itu_wood"/>
  </shape>
  <shape type="cube" id="slot_obj_6">
    <transform name="to_world">
